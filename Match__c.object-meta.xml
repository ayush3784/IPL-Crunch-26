<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>IPL Match</label>
    <pluralLabel>IPL Matches</pluralLabel>
    <nameField>
        <label>Match ID</label>
        <type>Text</type>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>

    <fields>
        <fullName>Season__c</fullName>
        <label>Season</label>
        <type>Number</type>
        <precision>4</precision>
        <scale>0</scale>
    </fields>

    <fields>
        <fullName>Date__c</fullName>
        <label>Match Date</label>
        <type>Date</type>
    </fields>

    <fields>
        <fullName>Venue__c</fullName>
        <label>Venue</label>
        <type>Text</type>
        <length>100</length>
    </fields>

    <fields>
        <fullName>City__c</fullName>
        <label>City</label>
        <type>Text</type>
        <length>50</length>
    </fields>

    <fields>
        <fullName>Team1__c</fullName>
        <label>Team 1</label>
        <type>Text</type>
        <length>100</length>
    </fields>

    <fields>
        <fullName>Team2__c</fullName>
        <label>Team 2</label>
        <type>Text</type>
        <length>100</length>
    </fields>

    <fields>
        <fullName>Toss_Winner__c</fullName>
        <label>Toss Winner</label>
        <type>Text</type>
        <length>100</length>
    </fields>

    <fields>
        <fullName>Toss_Decision__c</fullName>
        <label>Toss Decision</label>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <value><fullName>bat</fullName><label>Bat</label></value>
                <value><fullName>field</fullName><label>Field</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>

    <fields>
        <fullName>Winner__c</fullName>
        <label>Winner</label>
        <type>Text</type>
        <length>100</length>
    </fields>

    <fields>
        <fullName>Win_By_Runs__c</fullName>
        <label>Win By Runs</label>
        <type>Number</type>
        <precision>5</precision>
        <scale>0</scale>
    </fields>

    <fields>
        <fullName>Win_By_Wickets__c</fullName>
        <label>Win By Wickets</label>
        <type>Number</type>
        <precision>2</precision>
        <scale>0</scale>
    </fields>

    <fields>
        <fullName>Player_Of_Match__c</fullName>
        <label>Player of Match</label>
        <type>Text</type>
        <length>100</length>
    </fields>

    <fields>
        <fullName>Toss_Won_Match__c</fullName>
        <label>Toss Won Match</label>
        <type>Formula</type>
        <formula>IF(Toss_Winner__c == Winner__c, TRUE, FALSE)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <returnType>Checkbox</returnType>
    </fields>

</CustomObject>
